{
  "name": "just-draw",
  "private": true,
  "version": "1.0.0",
  "description": "A set of exercise to practice drawing organized by topic",
  "license": "0BSD",
  "scripts": {
    "build": "spago build",
    "build:css": "npx @tailwindcss/cli -i ./styles/globals.css -o ./dist/style.css",
    "predev": "npm run build && npm run build:css",
    "dev": "node ./build.mjs --watch",
    "prestart": "npm run build && npm run build:css",
    "start": "node ./build.mjs --watch",
    "prebundle": "npm run build && npm run build:css",
    "bundle": "node ./build.mjs",
    "deploy": "npm run bundle && gh-pages -d dist --nojekyll",
    "test": "npm run bundle",
    "format": "purs-tidy format-in-place src test"
  },
  "dependencies": {
    "daisyui": "^5.0.43",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "esbuild": "^0.25.0",
    "esbuild-copy-static-files": "^0.1.0",
    "esbuild-plugin-purescript": "^1.1.1",
    "gh-pages": "^6.3.0",
    "purescript": "^0.15.15",
    "purs-tidy": "^0.11.0",
    "spago": "^0.93.41",
    "tailwindcss": "^4.1.11"
  }
}
